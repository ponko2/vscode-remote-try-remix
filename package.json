{
  "name": "vscode-remote-try-remix",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build-storybook": "storybook build",
    "dev": "react-router dev",
    "fix": "run-s fix:oxlint fix:oxfmt fix:prisma-case fix:prisma",
    "fix:oxfmt": "oxfmt",
    "fix:oxlint": "oxlint --fix",
    "fix:prisma": "prisma format",
    "fix:prisma-case": "prisma-case-format --file prisma/schema.prisma",
    "generate": "run-p --aggregate-output -c -l generate:*",
    "generate:prisma": "prisma generate",
    "generate:react-router": "react-router typegen",
    "lint": "run-p --aggregate-output -c -l lint:*",
    "lint:oxfmt": "oxfmt --check",
    "lint:oxlint": "oxlint",
    "setup": "corepack enable pnpm",
    "start": "react-router-serve ./build/server/index.js",
    "storybook": "storybook dev -p 6006",
    "test": "vitest --passWithNoTests",
    "test-storybook": "vitest --project=storybook",
    "typecheck": "tsc --build --noEmit"
  },
  "dependencies": {
    "@conform-to/react": "^1.17.1",
    "@conform-to/zod": "^1.17.1",
    "@dotenvx/dotenvx": "^1.54.1",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-router/fs-routes": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "remeda": "^2.33.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/preset-typescript": "7.28.5",
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@react-router/dev": "7.13.1",
    "@storybook/addon-a11y": "10.2.17",
    "@storybook/addon-docs": "10.2.17",
    "@storybook/addon-links": "10.2.17",
    "@storybook/addon-vitest": "10.2.17",
    "@storybook/react-vite": "10.2.17",
    "@tailwindcss/vite": "4.2.1",
    "@tsconfig/remix": "2.0.7",
    "@tsconfig/strictest": "2.0.8",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "globals": "17.4.0",
    "lefthook": "2.1.4",
    "npm-run-all2": "8.0.4",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "1.58.2",
    "prisma": "7.5.0",
    "prisma-case-format": "2.2.1",
    "storybook": "10.2.17",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-babel": "1.5.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.11.1",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@10.32.1"
}
